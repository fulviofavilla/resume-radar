# LLM provider - use one of the options below:

# Option A: OpenAI API (default)
OPENAI_API_KEY=sk-...

# Option B: Local LLM via Ollama or LM Studio
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_MODEL=llama3.1:8b
# OPENAI_EMBEDDING_MODEL=nomic-embed-text

# Adzuna (optional - free tier at https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_API_KEY=
ADZUNA_COUNTRY=us

# ChromaDB (defaults work with docker compose - only change if running manually)
CHROMA_HOST=vectordb
CHROMA_PORT=8000

# Agent settings
MAX_JOBS_TO_FETCH=10
TOP_JOBS_FOR_ANALYSIS=5

# Redis - job store + rate limiting backend
REDIS_URL=redis://redis:6379